<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 CyberBot — Cybersecurity Awareness Assistant"
        Height="720" Width="920"
        MinHeight="500" MinWidth="680"
        Background="#0D1117"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER: ASCII Art Logo ══ -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,0,2"
                Padding="0,10,0,10">
            <TextBlock xml:space="preserve"
                       HorizontalAlignment="Center"
                       FontFamily="Courier New"
                       FontSize="11"
                       Foreground="#58FFBE"
                       IsHitTestVisible="False">  ╔══════════════════════════════════════════════════╗
  ║                                                  ║
  ║    ░█▀▀░█░█░█▀▄░█▀▀░█▀▄░█▀▄░█▀█░▀█▀              ║
  ║    ░█░░░░█░░█▀▄░█▀▀░█▀▄░█▀▄░█░█░░█░              ║
  ║    ░▀▀▀░░▀░░▀▀░░▀▀▀░▀░▀░▀▀░░▀▀▀░░▀░              ║
  ║                                                  ║
  ║       🔒  CYBERSECURITY AWARENESS BOT  🔒        ║
  ║          Protecting You in the Digital World     ║
  ║                                                  ║
  ╚══════════════════════════════════════════════════╝</TextBlock>
        </Border>

        <!-- ══ CHAT DISPLAY AREA ══ -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0D1117">
            <ItemsControl x:Name="ChatList" Margin="14,10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Border x:Name="MessageBubble"
                                    Background="#21262D"
                                    CornerRadius="12,12,12,3"
                                    Padding="14,10"
                                    MaxWidth="560"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,80,0">
                                <StackPanel>
                                    <TextBlock x:Name="SenderLabel"
                                               Text="{Binding Sender}"
                                               Foreground="#58A6FF"
                                               FontWeight="Bold"
                                               FontSize="11"
                                               Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="#C9D1D9"
                                               FontSize="13.5"
                                               TextWrapping="Wrap"
                                               LineHeight="20"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter TargetName="MessageBubble" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="MessageBubble" Property="Background" Value="#1C3A5E"/>
                                <Setter TargetName="MessageBubble" Property="CornerRadius" Value="12,12,3,12"/>
                                <Setter TargetName="MessageBubble" Property="Margin" Value="80,0,0,0"/>
                                <Setter TargetName="SenderLabel" Property="Foreground" Value="#3FB950"/>
                                <Setter TargetName="SenderLabel" Property="HorizontalAlignment" Value="Right"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ══ INPUT AREA ══ -->
        <Border Grid.Row="2" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Text input with placeholder overlay -->
                <Grid Grid.Column="0">
                    <TextBox x:Name="InputBox"
                             Background="#0D1117"
                             Foreground="#E6EDF3"
                             CaretBrush="#58A6FF"
                             BorderBrush="#30363D"
                             BorderThickness="1"
                             FontSize="14"
                             Padding="12,9"
                             VerticalContentAlignment="Center"
                             KeyDown="InputBox_KeyDown"
                             TextChanged="InputBox_TextChanged"/>
                    <TextBlock x:Name="PlaceholderText"
                               Text="Type your message and press Enter..."
                               Foreground="#484F58"
                               FontSize="14"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Send button with rounded style and hover effect -->
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send  ➤"
                        Click="SendButton_Click"
                        Margin="10,0,0,0"
                        Padding="22,9"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1F6FEB"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#388BFD"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#1158C7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- ══ STATUS BAR ══ -->
        <Border Grid.Row="3" Background="#010409" Padding="14,5">
            <TextBlock x:Name="StatusText"
                       Text="CyberBot v2.0  |  Cybersecurity Awareness Assistant"
                       Foreground="#484F58"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>
